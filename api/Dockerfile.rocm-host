# Knowledge Graph API Server - ROCm Official Image
#
# Uses AMD's official ROCm PyTorch image which has all ROCm libraries
# properly configured. This avoids library compatibility issues.
#
# Base image includes:
#   - ROCm 7.2.3
#   - Python 3.12
#   - PyTorch 2.9.1 with ROCm support
#
# Published as: ghcr.io/aaronsb/knowledge-graph-system/kg-api:rocm72-host
# Usage: GPU_MODE=amd-host ./operator.sh start  (ADR-101)

FROM rocm/pytorch:rocm7.2.3_ubuntu24.04_py3.12_pytorch_release_2.9.1

# Build metadata
ARG GIT_COMMIT=unknown
ARG BUILD_DATE=unknown
LABEL org.opencontainers.image.revision="${GIT_COMMIT}"
LABEL org.opencontainers.image.created="${BUILD_DATE}"
LABEL org.opencontainers.image.title="Knowledge Graph API (ROCm)"
LABEL org.opencontainers.image.description="FastAPI server with ROCm GPU support"

WORKDIR /app

# Install system dependencies (curl for healthcheck, libpq for postgres)
RUN apt-get update && apt-get install -y \
    libpq5 \
    libpq-dev \
    curl \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements and install (torch already in base image)
COPY requirements.txt .
RUN grep -v "^torch" requirements.txt | grep -v "^torchvision" > requirements-no-torch.txt && \
    pip install --no-cache-dir -r requirements-no-torch.txt

# Copy application code
COPY api/ /app/api/
COPY schema/ /app/schema/
# Offline backup-object oracle: the single source of truth for kg-backup/2 validation.
# Shipped so the API can load it by path for POST /admin/backup/verify. Stdlib-only /
# standalone — no api-package coupling. Copy just the one file (not the dir) to avoid
# pulling in __pycache__ and unrelated lint scripts.
COPY scripts/development/lint/lint_backup.py /app/scripts/development/lint/lint_backup.py

# Set Python path for imports
ENV PYTHONPATH=/app

# Pre-bake the default nomic-first embedding models (text + vision) into the
# image at /opt/hf-seed — a path OUTSIDE the runtime cache volume. Same shared
# bake script + entrypoint as api/Dockerfile, so the CPU/NVIDIA and ROCm images
# behave identically (offline first boot). See ADR-103 / ADR-039. The bake loads
# on CPU at build time (no GPU during docker build) — it only warms the cache.
RUN HF_HOME=/opt/hf-seed python /app/api/bake_embedding_models.py

# First-boot cache seeder (copies /opt/hf-seed into the mounted hf_cache volume).
# Runs as the runtime user, seeding $HOME/.cache — root here, api in the standard
# image; the same script works for both. See ADR-103.
COPY api/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Run as the user inherited from runtime (matches host UID for volume permissions)
# The docker-compose can specify user: "${UID}:${GID}" if needed

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:8000/health || exit 1

# Seed the baked model cache on first boot, then start the API.
ENTRYPOINT ["docker-entrypoint.sh"]

CMD ["uvicorn", "api.app.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
