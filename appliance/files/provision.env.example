# ============================================================================
# provision.env — declarative first-boot configuration for the KG appliance
# ============================================================================
#
# OPTIONAL. If this file is present at /etc/kg/provision.env when the appliance
# first boots, kg-firstboot.sh sources it and provisions declaratively instead
# of falling back to DHCP-IP + no-AI-key. Absent → the box still comes up; you
# finish setup in the web UI.
#
# Deliver it at deploy time via cloud-init user-data (see appliance/README.md):
#
#   #cloud-config
#   write_files:
#     - path: /etc/kg/provision.env
#       permissions: '0600'
#       content: |
#         KG_WEB_HOSTNAME=kg.example.com
#         KG_AI_PROVIDER=anthropic
#         KG_AI_MODEL=claude-sonnet-4
#         KG_AI_KEY=sk-ant-...
#
# This is the appliance's single declarative control surface. It is sourced as
# shell, so keep values quoted if they contain spaces. Unknown keys are ignored,
# so it is forward-compatible — new provisioning knobs slot in here.
# ============================================================================

# --- Web / network -----------------------------------------------------------
# Public hostname or IP for OAuth redirects + API URLs. If unset, the appliance
# derives it from the DHCP-assigned primary IP at first boot.
#KG_WEB_HOSTNAME=kg.example.com

# --- Reasoning provider (extraction) -----------------------------------------
# Embeddings are ALWAYS local (baked nomic) — no key needed. These configure the
# remote *reasoning* LLM used for concept extraction. Omit all three to leave AI
# unconfigured (finish in the web UI later).
#   provider: openai | anthropic | openrouter
#KG_AI_PROVIDER=anthropic
#KG_AI_MODEL=claude-sonnet-4
#KG_AI_KEY=

# --- Password policy ---------------------------------------------------------
# random (default): strong random admin password, written to /root/kg-credentials.txt
# simple: Password1! — INSECURE, eval/throwaway only.
#KG_PASSWORD_MODE=random
